<Window x:Class="chengkong.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:chengkong"
        mc:Ignorable="d"
        Title="设备 SSH 工具（串口 + Telnet）" Height="620" Width="1080"
        Background="#FFF5F5F7"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        Closing="MainWindow_Closing"
        FontSize="13">

    <Window.Resources>
        <!-- 文本框统一样式 -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FF0078D4"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 密码框统一样式 -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- 标签统一样式 -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <!-- 分组框样式 -->
        <Style x:Key="GroupPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="6,4"/>
        </Style>

        <!-- 主按钮 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FF0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF106EBE"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFB0B0B0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮（断开） -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#FF707070"/>
            <Setter Property="Width" Value="60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF505050"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFB0B0B0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 卡片标题 -->
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF666666"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- 字段位置下拉框样式 -->
        <Style x:Key="FieldPositionCombo" TargetType="ComboBox">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <TabControl Name="MainTabControl" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>

            <!-- ============== 串口会话 Tab ============== -->
            <TabItem Header="串口会话">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- SSH 连接 -->
                    <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource GroupPanel}">
                        <StackPanel>
                            <TextBlock Text="SSH 连接" Style="{StaticResource GroupTitle}"/>
                            <WrapPanel>
                                <TextBlock Text="IP" Style="{StaticResource LabelText}"/>
                                <TextBox Name="SerialIp" Text="10.10.10.3" Width="140" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="端口" Style="{StaticResource LabelText}" Margin="20,0,6,0"/>
                                <TextBox Name="SerialPort" Text="22" Width="50" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="用户" Style="{StaticResource LabelText}" Margin="20,0,6,0"/>
                                <TextBox Name="SerialUser" Text="root" Width="80" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="密码" Style="{StaticResource LabelText}" Margin="20,0,6,0"/>
                                <PasswordBox Name="SerialPwd" Password="andisat" Width="120" Style="{StaticResource ModernPasswordBox}"/>
                                <Button Name="SerialConnectBtn" Content="连接" Margin="20,0,0,0" Click="SerialConnect_Click" Style="{StaticResource PrimaryButton}"/>
                                <Button Name="SerialDisconnectBtn" Content="断开" Margin="6,0,0,0" Click="SerialDisconnect_Click" Style="{StaticResource SecondaryButton}" IsEnabled="False"/>
                                <TextBlock Name="SerialStatusText" Text="● 未连接" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#FFD32F2F" FontWeight="SemiBold"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 运行参数 -->
                    <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource GroupPanel}">
                        <StackPanel>
                            <TextBlock Text="运行参数" Style="{StaticResource GroupTitle}"/>
                            <WrapPanel>
                                <TextBlock Text="间隔时间" Style="{StaticResource LabelText}"/>
                                <TextBox Name="SerialIntervalTime" Text="60" Width="50" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="秒" Style="{StaticResource LabelText}" Margin="0,0,20,0"/>
                                <TextBlock Text="总测试时间" Style="{StaticResource LabelText}"/>
                                <TextBox Name="SerialTotalTime" Text="2" Width="50" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="分钟" Style="{StaticResource LabelText}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 命令 + 解析 -->
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource GroupPanel}">
                        <StackPanel>
                            <TextBlock Text="串口 命令与解析" Style="{StaticResource GroupTitle}"/>
                            <WrapPanel>
                                <TextBlock Text="串口命令" Style="{StaticResource LabelText}"/>
                                <TextBox Name="SerialSshCommand" Text="bsp cmd st sensor_pos" Width="280" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="关键字" Style="{StaticResource LabelText}" Margin="20,0,6,0"
                                           ToolTip="在命令返回结果中匹配一行作为目标行。"/>
                                <TextBox Name="SerialKeyword" Text="current pos" Width="100" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="取第几段" Style="{StaticResource LabelText}" Margin="20,0,6,0"
                                           ToolTip="把关键字所在行按空格/Tab 分割成多段，取第 N 段作为解析值（从 1 开始）。"/>
                                <ComboBox Name="SerialFieldPosition" SelectedIndex="2" Style="{StaticResource FieldPositionCombo}">
                                    <ComboBoxItem>1</ComboBoxItem>
                                    <ComboBoxItem>2</ComboBoxItem>
                                    <ComboBoxItem>3</ComboBoxItem>
                                    <ComboBoxItem>4</ComboBoxItem>
                                    <ComboBoxItem>5</ComboBoxItem>
                                    <ComboBoxItem>6</ComboBoxItem>
                                    <ComboBoxItem>7</ComboBoxItem>
                                    <ComboBoxItem>8</ComboBoxItem>
                                    <ComboBoxItem>9</ComboBoxItem>
                                    <ComboBoxItem>10</ComboBoxItem>
                                </ComboBox>
                                <Button Name="SerialSendButton" Content="下发" Margin="30,0,0,0" Click="SerialSend_Click" Style="{StaticResource PrimaryButton}"/>
                                <Button Name="SerialStopButton" Content="停止" Margin="6,0,0,0" Click="SerialStop_Click" Style="{StaticResource SecondaryButton}" IsEnabled="False"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 双栏日志 -->
                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource GroupPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="操作日志" Style="{StaticResource GroupTitle}"/>
                            <ListView Name="SerialOpLogListView"
                                      Grid.Row="1"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      VirtualizingStackPanel.ScrollUnit="Pixel"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True"
                                      Background="#FFFAFAFA"
                                      BorderBrush="#FFE0E0E0"
                                      BorderThickness="1">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" FontFamily="Consolas, Microsoft YaHei UI" FontSize="12" TextWrapping="Wrap" Padding="8,2"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource GroupPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="解析结果" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Name="SerialCountTextBlock" Grid.Row="1" Margin="0,0,0,6"
                                       Padding="10,6" Background="#FFEEEEEE" FontWeight="SemiBold" Foreground="#FF333333" Text="计数"/>
                            <ListView Name="SerialResultListView" Grid.Row="2"
                                      Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                      VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Extended">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Padding="4,2"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOk}" Value="True">
                                                <Setter Property="Foreground" Value="#FF1B7D3A"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============== Telnet 会话 Tab ============== -->
            <TabItem Header="Telnet 会话">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- SSH 连接 -->
                    <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource GroupPanel}">
                        <StackPanel>
                            <TextBlock Text="SSH 连接（登录后执行 telnet 0 2323）" Style="{StaticResource GroupTitle}"/>
                            <WrapPanel>
                                <TextBlock Text="IP" Style="{StaticResource LabelText}"/>
                                <TextBox Name="TelnetIp" Text="10.10.10.3" Width="140" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="端口" Style="{StaticResource LabelText}" Margin="20,0,6,0"/>
                                <TextBox Name="TelnetPort" Text="22" Width="50" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="用户" Style="{StaticResource LabelText}" Margin="20,0,6,0"/>
                                <TextBox Name="TelnetUser" Text="root" Width="80" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="密码" Style="{StaticResource LabelText}" Margin="20,0,6,0"/>
                                <PasswordBox Name="TelnetPwd" Password="andisat" Width="120" Style="{StaticResource ModernPasswordBox}"/>
                                <Button Name="TelnetConnectBtn" Content="连接" Margin="20,0,0,0" Click="TelnetConnect_Click" Style="{StaticResource PrimaryButton}"/>
                                <Button Name="TelnetDisconnectBtn" Content="断开" Margin="6,0,0,0" Click="TelnetDisconnect_Click" Style="{StaticResource SecondaryButton}" IsEnabled="False"/>
                                <TextBlock Name="TelnetStatusText" Text="● 未连接" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#FFD32F2F" FontWeight="SemiBold"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 运行参数 -->
                    <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource GroupPanel}">
                        <StackPanel>
                            <TextBlock Text="运行参数" Style="{StaticResource GroupTitle}"/>
                            <WrapPanel>
                                <TextBlock Text="间隔时间" Style="{StaticResource LabelText}"/>
                                <TextBox Name="TelnetIntervalTime" Text="60" Width="50" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="秒" Style="{StaticResource LabelText}" Margin="0,0,20,0"/>
                                <TextBlock Text="总测试时间" Style="{StaticResource LabelText}"/>
                                <TextBox Name="TelnetTotalTime" Text="2" Width="50" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="分钟" Style="{StaticResource LabelText}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 命令 + 解析 -->
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource GroupPanel}">
                        <StackPanel>
                            <TextBlock Text="Telnet 命令与解析" Style="{StaticResource GroupTitle}"/>
                            <WrapPanel>
                                <TextBlock Text="Telnet命令" Style="{StaticResource LabelText}"/>
                                <TextBox Name="TelnetSshCommand" Text="get-if-rx-curesn0:@bid=3&amp;pid=1&amp;chid=1" Width="280" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="关键字" Style="{StaticResource LabelText}" Margin="20,0,6,0"
                                           ToolTip="在命令返回结果中匹配一行作为目标行。"/>
                                <TextBox Name="TelnetKeyword" Text="EBN0" Width="100" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="取第几段" Style="{StaticResource LabelText}" Margin="20,0,6,0"
                                           ToolTip="把关键字所在行按空格/Tab 分割成多段，取第 N 段作为解析值（从 1 开始）。"/>
                                <ComboBox Name="TelnetFieldPosition" SelectedIndex="5" Style="{StaticResource FieldPositionCombo}">
                                    <ComboBoxItem>1</ComboBoxItem>
                                    <ComboBoxItem>2</ComboBoxItem>
                                    <ComboBoxItem>3</ComboBoxItem>
                                    <ComboBoxItem>4</ComboBoxItem>
                                    <ComboBoxItem>5</ComboBoxItem>
                                    <ComboBoxItem>6</ComboBoxItem>
                                    <ComboBoxItem>7</ComboBoxItem>
                                    <ComboBoxItem>8</ComboBoxItem>
                                    <ComboBoxItem>9</ComboBoxItem>
                                    <ComboBoxItem>10</ComboBoxItem>
                                </ComboBox>
                                <Button Name="TelnetSendButton" Content="下发" Margin="30,0,0,0" Click="TelnetSend_Click" Style="{StaticResource PrimaryButton}"/>
                                <Button Name="TelnetStopButton" Content="停止" Margin="6,0,0,0" Click="TelnetStop_Click" Style="{StaticResource SecondaryButton}" IsEnabled="False"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 双栏日志 -->
                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource GroupPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="操作日志" Style="{StaticResource GroupTitle}"/>
                            <ListView Name="TelnetOpLogListView"
                                      Grid.Row="1"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      VirtualizingStackPanel.ScrollUnit="Pixel"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True"
                                      Background="#FFFAFAFA"
                                      BorderBrush="#FFE0E0E0"
                                      BorderThickness="1">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" FontFamily="Consolas, Microsoft YaHei UI" FontSize="12" TextWrapping="Wrap" Padding="8,2"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource GroupPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="解析结果" Style="{StaticResource GroupTitle}"/>
                            <TextBlock Name="TelnetCountTextBlock" Grid.Row="1" Margin="0,0,0,6"
                                       Padding="10,6" Background="#FFEEEEEE" FontWeight="SemiBold" Foreground="#FF333333" Text="计数"/>
                            <ListView Name="TelnetResultListView" Grid.Row="2"
                                      Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                      VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Extended">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Padding="4,2"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOk}" Value="True">
                                                <Setter Property="Foreground" Value="#FF1B7D3A"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOk}" Value="False">
                                                <Setter Property="Foreground" Value="#FFD32F2F"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
